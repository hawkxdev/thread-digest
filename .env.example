# Telegram Bot
BOT_TOKEN=000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
ADMIN_USER_ID=123456789
# Telegram chat для алертов об ошибках от TelegramErrorHandler (обычно = ADMIN_USER_ID)
ADMIN_CHAT_ID=123456789

# DeepSeek AI (primary summarizer)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=4000
DEEPSEEK_TEMPERATURE=0.3

# Reddit (public .json endpoint, без OAuth)
REDDIT_USER_AGENT=thread-digest:v0.1 (by /u/hawkxdev)
REDDIT_RATE_LIMIT_QPM=5
REDDIT_FETCH_TIMEOUT=30
REDDIT_COMMENT_LIMIT=500
REDDIT_COMMENT_DEPTH=10

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/thread_digest.db

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_ROTATION=1 day
LOG_RETENTION=30 days
